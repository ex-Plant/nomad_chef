# --- Postgres (local Docker) ---
POSTGRES_DB=chef
POSTGRES_USER=chef
POSTGRES_PASSWORD=chef
DOCKER_CONTAINER=chef-cms

# --- Payload (required to boot) ---
# Local dev: postgres://chef:chef@localhost:5434/chef
# Prod: Neon connection string
DB_POSTGRES_URL=postgres://chef:chef@localhost:5434/chef
PAYLOAD_SECRET=change-me

# --- Media (Vercel Blob) ---
# Enable once vercelBlobStorage plugin is uncommented in payload.config.ts
# BLOB_READ_WRITE_TOKEN=

# --- SMTP (Nodemailer) ---
# Enable once nodemailer adapter is uncommented in payload.config.ts
# EMAIL_HOST=
# EMAIL_USER=
# EMAIL_PASS=

# --- Seed scripts (local-only; only needed when running `pnpm seed:admin`) ---
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=
