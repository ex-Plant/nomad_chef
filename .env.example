# --- Postgres (local Docker) ---
POSTGRES_DB=chef
POSTGRES_USER=chef
POSTGRES_PASSWORD=chef
DOCKER_CONTAINER=chef-cms

# --- Payload (required to boot) ---
# Local dev: postgres://chef:chef@localhost:5434/chef
# Prod: Neon connection string
DB_POSTGRES_URL=postgres://chef:chef@localhost:5434/chef
PAYLOAD_SECRET=change-me

# --- Prod dump source (used by `pnpm db:dump`) ---
# Neon prod URL — copy from Vercel project (Storage → Neon → .env tab).
# Must include sslmode=require.
PROD_DB_POSTGRES_URL=

# --- Media (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=

# --- SMTP (Nodemailer) ---
# Wired via the nodemailer adapter in payload.config.ts. The contact form
# server action calls payload.sendEmail() through that adapter.
EMAIL_HOST=
EMAIL_USER=
EMAIL_PASS=
# Inbox that receives contact-form submissions.
EMAIL_TO=

# --- Site ---
# Canonical prod URL. Used for sitemap, robots, OG, and all order/email links.
SITE_URL=http://localhost:3000

# --- Przelewy24 (checkout; required to boot) ---
P24_MERCHANT_ID=
P24_POS_ID=
P24_CRC=
P24_API_KEY=
# Optional toggle — "true" hits the P24 sandbox host instead of production.
# P24_SANDBOX=true

# --- Cron (payment reconciliation) ---
# Shared secret guarding /api/cron/reconcile-payments. Read at the route (NOT
# boot-required), so it's optional locally — the cron only runs on production.
# Set it in the Vercel project env, where Vercel auto-sends it as
# `Authorization: Bearer <CRON_SECRET>`. Generate one with: openssl rand -hex 32
CRON_SECRET=
