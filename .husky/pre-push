npm run typecheck

# --- Dump-on-push DB backup (appended) ---------------------------------------
# Local safety net taken on every `git push`: snapshots PROD (PROD_DB_POSTGRES_URL
# via the local $DOCKER_CONTAINER's pg_dump) into the gitignored dumps/ dir.
# Runs AFTER typecheck — no point dumping if the push would be rejected anyway —
# and BEFORE the watch-deploy block, so a failed dump aborts before a watcher is
# spawned. Blocks the push on a failed/empty dump: a backup you can't trust is
# worse than a loud failure. Requires the local Docker DB container to be up.
# This is the LOCAL layer; the scheduled off-site copy lives in
# .github/workflows/db-backup.yml. Set SKIP_DB_DUMP=1 to bypass (offline, CI).
if [ -z "${SKIP_DB_DUMP:-}" ]; then
  echo "Dumping DB before push..."
  if npm run db:dump && [ -s dumps/dump-latest.sql ]; then
    echo "✅ DB dump succeeded ($(du -h dumps/dump-latest.sql | cut -f1))"
  else
    echo "❌ DB dump failed or produced empty file — aborting push"
    exit 1
  fi

  # Keep dump-latest.sql plus timestamped copies from the last 7 days; drop older.
  pruned=$(find dumps -name 'dump-*.sql' ! -name 'dump-latest.sql' -mtime +7 -print -delete 2>/dev/null | wc -l | tr -d ' ')
  echo "✅ Pruned ${pruned:-0} old dump(s)"
fi

# Background watcher: tails the Vercel deployment that this push triggers and
# prints its state transitions (… BUILDING → READY / ERROR) to this terminal.
# Detached subshell so `git push` returns immediately when the hook exits.
# DEPLOY_SHA pins the watcher to THIS commit's deploy (matched by SHA), not "newest".
# Set SKIP_WATCH_DEPLOY=1 to bypass (CI machines, offline pushes, etc.).
#
# Foreground auth precheck FIRST (~1s): a dead local CLI token can't watch
# deploys, and a backgrounded watcher would just poll blind and then misblame the
# Git integration 3 min later. Surface it loudly here instead. Non-fatal — never
# block a push over LOCAL auth; just skip the (useless) watcher.
if [ -z "${SKIP_WATCH_DEPLOY:-}" ]; then
  if bash scripts/watch-deploy.sh --check-auth; then
    ( DEPLOY_SHA="$(git rev-parse HEAD)" bash scripts/watch-deploy.sh & )
  else
    echo "  🔒 vercel: skipping deploy watcher — fix local CLI auth (see above), then push again to tail." >&2
  fi
fi
